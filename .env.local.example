# ─── Vercel AI Gateway ──────────────────────────────────────────────────────
# Get from: Vercel Dashboard → AI Gateway → API Keys
# Used for all LLM calls (Anthropic, embeddings, etc.)
AI_GATEWAY_API_KEY=

# ─── Supabase ───────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Workflow DevKit ────────────────────────────────────────────────────────
# Automatically configured by `withWorkflow()` in next.config.ts.
# For local dev, run: npx workflow dev  (starts the local workflow executor)
# No manual env vars needed for the basic local setup.

# ─── Exa (proactive web search + page fetch) ────────────────────────────────
# Get from: https://dashboard.exa.ai/api-keys
# Powers both search_web (Exa /search) and fetch_website (Exa /contents).
# Exa handles crawling, HTML→text extraction, and the SSRF surface server-side.
# If EXA_API_KEY is unset, both tools return "unavailable" instead of crashing
# — so local dev without the key still works, the agent just can't look things up.
EXA_API_KEY=

# ─── Resend (end-of-chat recap email) ───────────────────────────────────────
# Get from: https://resend.com/api-keys
# If RESEND_API_KEY is unset, /api/email-capture still saves the row but
# skips the email send (logs a warning) — useful for local dev without
# burning Resend quota or needing a verified sender.
RESEND_API_KEY=
RESEND_FROM_EMAIL="LCA <onboarding@resend.dev>"
