# ─── Vercel AI Gateway ──────────────────────────────────────────────────────
# Get from: Vercel Dashboard → AI Gateway → API Keys
# Used for all LLM calls (Anthropic, embeddings, etc.)
AI_GATEWAY_API_KEY=

# ─── Supabase ───────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Vercel Sandbox ─────────────────────────────────────────────────────────
# @vercel/sandbox reads a short-lived OIDC token from the env. On Vercel
# deployments this is injected automatically. For local dev you populate it
# (and the linked project metadata) by running:
#
#   vercel login          # one-time, writes auth file under %APPDATA%\com.vercel.cli
#   vercel link           # creates .vercel/project.json in this repo
#   vercel env pull       # writes VERCEL_OIDC_TOKEN + project envs into .env.local
#
# OIDC tokens expire every 12 hours — re-run `vercel env pull` if Sandbox
# starts 401-ing.
VERCEL_OIDC_TOKEN=

# ─── Workflow DevKit ────────────────────────────────────────────────────────
# Automatically configured by `withWorkflow()` in next.config.ts.
# For local dev, run: npx workflow dev  (starts the local workflow executor)
# No manual env vars needed for the basic local setup.
